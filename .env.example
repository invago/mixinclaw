# Mixin Messenger Channel for OpenClaw

# Mixin Bot credentials (from https://developers.mixin.one/dashboard)
MIXIN_APP_ID=your-app-uuid
MIXIN_SESSION_ID=your-session-uuid
MIXIN_SERVER_PUBLIC_KEY=your-server-public-key-base64
MIXIN_SESSION_PRIVATE_KEY=your-ed25519-private-key-base64

# Optional: override config path
# OPENCLAW_CONFIG_PATH=~/.openclaw/config.json
